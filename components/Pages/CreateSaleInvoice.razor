@page "/create-sale-invoice"

<PageTitle>Create Sale Invoice</PageTitle>
<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/theme.css" />
    <link rel="stylesheet" href="assets/css/base.css" />
    <link rel="stylesheet" href="assets/css/components.css" />
    <link rel="stylesheet" href="assets/css/create-sale-invoice.css" />
    <link rel="stylesheet" href="assets/css/mobile.css" media="screen and (max-width: 768px)" />
</HeadContent>

<!-- ============== TOPBAR ============== -->
  <div data-component="topbar"></div>

  <!-- ============== DESKTOP ============== -->
  <div class="desktop-wrap">
    <main class="page">
      <div class="page-head">
        <div>
          <div class="eyebrow" data-i18n="page-eyebrow">New Transaction · Installment Sale</div>
          <h1 data-i18n="page-title">Create Sale Invoice</h1>
          <div class="sub" data-i18n="page-sub">Record a new sale, capture payment terms, and generate an installment
            plan.</div>
        </div>
        <div><button class="btn ghost" data-i18n="btn-save-draft">Save draft</button></div>
      </div>

      <section class="card">
        <div class="card-head">
          <div class="card-title" data-i18n="card-sale-type">Sale Type</div>
        </div>
        <div class="card-body">
          <div class="sale-type" id="sale-type">
            <button data-v="cash" data-i18n="st-cash">Cash</button>
            <button data-v="credit" data-i18n="st-credit">Credit</button>
            <button data-v="advance" data-i18n="st-advance">Advance</button>
            <button data-v="installment" class="active" data-i18n="st-installment">Installment</button>
          </div>
        </div>
      </section>

      <section class="card" id="card-txn">
        <div class="card-head">
          <div>
            <div class="card-title" data-i18n="card-txn">Transaction Details</div>
            <div class="card-sub" data-i18n="card-txn-sub">Invoice identifiers, customer account and payment terms.
            </div>
          </div>
          <button class="card-collapse" onclick="toggleCard('card-txn')"><svg class="chevron" width="14" height="14"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 15l6-6 6 6" />
            </svg></button>
        </div>
        <div class="card-body">
          <div class="form-grid">
            <div class="field"><label data-i18n="lbl-currency">Currency</label><select class="select">
                <option>USD — US Dollar</option>
                <option>EUR — Euro</option>
                <option>GBP — Pound Sterling</option>
              </select></div>
            <div class="field"><label data-i18n="lbl-store">Store</label>
              <div class="input-with-icon"><input class="input" value="Main Flagship Store" />
                <span class="input-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <path d="M3 9l1.5-5h15L21 9M4 9h16v11H4z" />
                    <path d="M9 20v-6h6v6" />
                  </svg></span>
              </div>
            </div>
            <div class="field"><label data-i18n="lbl-date-posted">Date Posted</label>
              <div class="input-with-icon"><input class="input" value="11/01/2023" />
                <span class="input-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <rect x="3" y="5" width="18" height="16" rx="2" />
                    <path d="M3 9h18M8 3v4M16 3v4" />
                  </svg></span>
              </div>
            </div>
            <div class="field"><label data-i18n="lbl-customer">Customer Account</label>
              <div class="input-with-icon"><input class="input" placeholder="Search or select customer…" />
                <span class="input-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="7" />
                    <path d="M21 21l-4.3-4.3" />
                  </svg></span>
              </div>
            </div>
            <div class="field"><label data-i18n="lbl-cash-acct">Cash Account (A/R)</label><input class="input"
                value="Accounts Receivable — Customers (1200-01)" disabled /></div>
            <div class="field"><label data-i18n="lbl-reference">Reference</label><input class="input mono"
                value="INV-2023-007" /></div>

            <div class="field"><label data-i18n="lbl-has-dp">Has Down Payment</label>
              <div class="switch on" id="dp-switch" onclick="toggleDP()">
                <div class="switch-track">
                  <div class="switch-thumb"></div>
                </div><span id="dp-label">Enabled</span>
              </div>
            </div>
            <div class="field dp-only"><label data-i18n="lbl-dp-acct">Down Payment Cash / Bank Account</label><select
                class="select">
                <option>Main Bank Account (1002-01)</option>
                <option>Petty Cash (1001-01)</option>
              </select></div>
            <div class="field dp-only"><label data-i18n="lbl-dp-amount">Down Payment Amount</label><input
                class="input mono" id="dp-amount" value="30.00" /></div>
          </div>
        </div>
      </section>

      <section class="card" id="card-info">
        <div class="card-head">
          <div class="card-title" data-i18n="card-info">Additional Info</div>
          <button class="card-collapse" onclick="toggleCard('card-info')"><svg class="chevron" width="14" height="14"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 15l6-6 6 6" />
            </svg></button>
        </div>
        <div class="card-body">
          <div class="form-grid" style="grid-template-columns:2fr 1fr">
            <div class="field"><label data-i18n="lbl-desc">Description</label><textarea class="textarea"
                placeholder="Internal notes or specific customer instructions…"></textarea></div>
            <div class="field"><label data-i18n="lbl-attach">Attachments</label>
              <div class="upload">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 16V4M7 9l5-5 5 5" />
                  <path d="M4 16v3a2 2 0 002 2h12a2 2 0 002-2v-3" />
                </svg>
                <div class="u-title" data-i18n="upload-title">Click to upload files</div>
                <div class="u-sub" data-i18n="upload-sub">PDF, PNG, JPG up to 10 MB</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="card">
        <div class="card-head">
          <div class="card-title" data-i18n="card-products">Products</div>
          <button class="btn link" onclick="addProduct()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
              <path d="M12 5v14M5 12h14" />
            </svg>
            <span data-i18n="btn-add-product">Add Product</span>
          </button>
        </div>
        <div class="card-body" style="padding:8px 10px 10px">
          <div class="thead">
            <div data-i18n="th-product">Product Name</div>
            <div data-i18n="th-sku">SKU</div>
            <div data-i18n="th-qty">Qty</div>
            <div data-i18n="th-price">Unit Price</div>
            <div data-i18n="th-total">Line Total</div>
            <div></div>
          </div>
          <div id="product-rows"></div>
        </div>
      </section>

      <section class="card" id="card-costs">
        <div class="card-head">
          <div>
            <div class="card-title" data-i18n="card-costs">Additional Costs &amp; Discounts</div>
            <div class="card-sub" data-i18n="card-costs-sub">Line-item charges and discounts. Taxes are handled
              separately below.</div>
          </div>
          <button class="card-collapse" onclick="toggleCard('card-costs')"><svg class="chevron" width="14" height="14"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 15l6-6 6 6" />
            </svg></button>
        </div>
        <div class="card-body" style="padding:8px 10px 10px">
          <div class="between" style="padding:4px 12px 6px">
            <div class="dim" style="font-size:11px;letter-spacing:.1em;text-transform:uppercase;font-weight:600">Extra
              Costs</div>
            <button class="btn link" onclick="addCost()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.4">
                <path d="M12 5v14M5 12h14" />
              </svg>Add Cost</button>
          </div>
          <div class="costs-head">
            <div data-i18n="ch-desc">Description</div>
            <div data-i18n="ch-type">Type</div>
            <div data-i18n="ch-rate">Rate / Basis</div>
            <div data-i18n="ch-amount">Amount</div>
            <div></div>
          </div>
          <div id="cost-rows"></div>
        </div>
      </section>

      <section class="card">
        <div class="card-head">
          <div class="card-title" data-i18n="card-tax">Tax</div>
        </div>
        <div class="card-body">
          <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr 1fr">
            <div class="field"><label data-i18n="lbl-tax-scheme">Tax Scheme</label>
              <select class="select" id="tax-scheme">
                <option value="exclusive">Tax exclusive (added)</option>
                <option value="inclusive">Tax inclusive (built-in)</option>
                <option value="none">No tax</option>
              </select>
            </div>
            <div class="field"><label data-i18n="lbl-tax-rate">Tax Rate (%)</label><input class="input num"
                id="tax-rate" value="5" /></div>
            <div class="field"><label data-i18n="lbl-tax-basis">Tax Basis</label><input class="input"
                value="Subtotal − Discounts" disabled /></div>
            <div class="field"><label data-i18n="lbl-tax-amount">Tax Amount</label><input class="input mono"
                id="tax-amount-display" value="$0.00" disabled /></div>
          </div>
        </div>
      </section>

      <section class="card" id="card-plan">
        <div class="card-head">
          <div>
            <div class="card-title" data-i18n="card-plan">Installment Plan</div>
            <div class="card-sub" data-i18n="card-plan-sub">Payment schedule for the balance remaining after down
              payment.</div>
          </div>
          <button class="card-collapse" onclick="toggleCard('card-plan')"><svg class="chevron" width="14" height="14"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 15l6-6 6 6" />
            </svg></button>
        </div>
        <div class="card-body">
          <div class="ins-summary">
            <div class="ins-stat">
              <div class="lbl" data-i18n="lbl-ins-total">Invoice Total</div>
              <div class="val num" id="ins-total">$0.00</div>
            </div>
            <div class="ins-stat warn">
              <div class="lbl" data-i18n="lbl-ins-down">Down Payment</div>
              <div class="val num" id="ins-down">−$0.00</div>
            </div>
            <div class="ins-stat primary">
              <div class="lbl" data-i18n="lbl-ins-remain">Installment Base</div>
              <div class="val num" id="ins-remain">$0.00</div>
            </div>
          </div>

          <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr 180px;margin-top:16px;align-items:flex-end">
            <div class="field"><label data-i18n="lbl-plan-n">Number of Installments</label><input class="input"
                id="plan-n" type="number" value="3" min="1" max="36" /></div>
            <div class="field"><label data-i18n="lbl-plan-start">Start Date</label>
              <div class="input-with-icon"><input class="input" id="plan-start" value="12/01/2023" />
                <span class="input-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <rect x="3" y="5" width="18" height="16" rx="2" />
                    <path d="M3 9h18M8 3v4M16 3v4" />
                  </svg></span>
              </div>
            </div>
            <div class="field"><label data-i18n="lbl-plan-freq">Frequency</label>
              <select class="select" id="plan-freq">
                <option>Monthly</option>
                <option>Bi-weekly</option>
                <option>Weekly</option>
                <option>Quarterly</option>
              </select>
            </div>
            <div><button class="btn primary" style="width:100%;justify-content:center"
                onclick="generatePlan()">Regenerate</button></div>
          </div>

          <div class="plan-table">
            <div class="plan-thead">
              <div data-i18n="plan-th-no">#</div>
              <div data-i18n="plan-th-due">Due Date</div>
              <div data-i18n="plan-th-amount">Amount</div>
              <div data-i18n="plan-th-status">Status</div>
              <div></div>
            </div>
            <div id="plan-rows"></div>
          </div>
          <div class="dim" style="font-size:11.5px;margin-top:8px">Sum of installments equals the installment base
            exactly. The final installment absorbs any rounding remainder.</div>
        </div>
      </section>

      <section class="card">
        <div class="totals">
          <div class="note">
            <strong>Accounting flow.</strong> Posting this invoice will debit Accounts Receivable by the invoice total,
            credit Sales Revenue for the taxable net, credit Tax Payable for the tax amount, and record the down payment
            against Cash / Bank. Each installment creates a scheduled receivable.
          </div>
          <dl>
            <dt data-i18n="dt-subtotal">Subtotal (net of line discounts)</dt>
            <dd class="num" id="t-subtotal">$0.00</dd>
            <dt data-i18n="dt-charges">Additional Charges</dt>
            <dd class="num pos" id="t-charges">+$0.00</dd>
            <dt data-i18n="dt-disc">Discounts</dt>
            <dd class="num neg" id="t-disc">−$0.00</dd>
            <dt data-i18n="dt-net">Taxable Net</dt>
            <dd class="num" id="t-net">$0.00</dd>
            <dt>Tax (<span id="t-tax-rate">5</span>%)</dt>
            <dd class="num pos" id="t-tax">+$0.00</dd>
            <div class="divider"></div>
            <dt data-i18n="dt-inv-total">Invoice Total</dt>
            <dd class="num" id="t-total">$0.00</dd>
            <dt data-i18n="dt-dp">− Down Payment</dt>
            <dd class="num neg" id="t-dp">−$0.00</dd>
            <div class="divider"></div>
            <div class="grand">
              <dt data-i18n="dt-balance">Balance to Finance</dt>
              <dd class="num" id="t-balance">$0.00</dd>
            </div>
          </dl>
        </div>
      </section>
    </main>

    <div class="page-footer">
      <button class="btn ghost" data-i18n="btn-cancel">Cancel</button>
      <button class="btn primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <path d="M5 12l5 5 9-11" />
        </svg>
        <span data-i18n="btn-submit">Submit Sale</span>
      </button>
    </div>
  </div>

  <!-- ============== MOBILE ============== -->
  <div class="mobile-wrap">
    <div class="mobile-frame">
      <div class="mobile-topbar">
        <button class="icon-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <path d="M15 18l-6-6 6-6" />
          </svg></button>
        <div>
          <div class="t-eyebrow" data-i18n="m-new-txn">New Transaction</div>
          <h1 data-i18n="m-create-invoice">Create Invoice</h1>
        </div>
        <button class="icon-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2">
            <circle cx="12" cy="5" r="1.5" />
            <circle cx="12" cy="12" r="1.5" />
            <circle cx="12" cy="19" r="1.5" />
          </svg></button>
      </div>

      <div class="mobile-body">
        <div class="mobile-sale-type" id="m-sale-type">
          <button data-v="cash" data-i18n="st-cash">Cash</button>
          <button data-v="credit" data-i18n="st-credit">Credit</button>
          <button data-v="advance">Adv.</button>
          <button data-v="installment" class="active" data-i18n="st-installment">Installment</button>
        </div>

        <section class="card">
          <div class="card-head">
            <div class="card-title">Transaction Details</div>
          </div>
          <div class="card-body">
            <div class="between" style="padding-bottom:8px"><span style="font-weight:600;font-size:13.5px"
                data-i18n="m-has-dp">Has Down Payment</span>
              <div class="switch on" id="m-dp-switch" onclick="mToggleDP()">
                <div class="switch-track">
                  <div class="switch-thumb"></div>
                </div>
              </div>
            </div>
            <div class="m-field"><label data-i18n="lbl-currency">Currency</label>
              <button class="m-picker" onclick="openSheet('sheet-currency')"><span id="m-currency">USD — US
                  Dollar</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </button>
            </div>
            <div class="m-field"><label>Store Location</label>
              <button class="m-picker" onclick="openSheet('sheet-store')"><span id="m-store">Main Downtown Hub</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </button>
            </div>
            <div class="m-field"><label data-i18n="lbl-customer">Customer Account</label>
              <button class="m-picker" onclick="openSheet('sheet-customer')">
                <span style="display:flex;align-items:center;gap:10px">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="7" />
                    <path d="M21 21l-4.3-4.3" />
                  </svg>
                  <span id="m-customer">Alex Thompson (#F-062)</span>
                </span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </button>
            </div>
            <div class="m-row2">
              <div class="m-field"><label data-i18n="lbl-reference">Reference</label><input class="input mono"
                  value="INV-062" /></div>
              <div class="m-field"><label data-i18n="lbl-date-posted">Date Posted</label>
                <button class="m-picker" onclick="openDate('m-date-posted')"><span id="m-date-posted">Oct 24,
                    2023</span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="5" width="18" height="16" rx="2" />
                    <path d="M3 9h18M8 3v4M16 3v4" />
                  </svg>
                </button>
              </div>
            </div>
            <div class="m-field m-dp-only"><label>Down Payment Account</label>
              <button class="m-picker" onclick="openSheet('sheet-dpacct')"><span id="m-dpacct">Merchant Operating
                  (Chase)</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M6 9l6 6 6-6" />
                </svg>
              </button>
            </div>
            <div class="m-field m-dp-only"><label data-i18n="lbl-dp-amount">Down Payment Amount</label>
              <input class="input mono" id="m-dp-amount" value="10.00" inputmode="decimal" />
            </div>
          </div>
        </section>

        <section class="card">
          <div class="card-head">
            <div class="card-title">Additional Information</div>
          </div>
          <div class="card-body">
            <div class="m-field"><label data-i18n="lbl-desc">Description</label><textarea class="textarea"
                style="min-height:80px" placeholder="Optional notes…"></textarea></div>
            <div class="m-field"><label data-i18n="lbl-attach">Attachments</label>
              <div class="upload" style="min-height:84px">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 16V4M7 9l5-5 5 5" />
                  <path d="M4 16v3a2 2 0 002 2h12a2 2 0 002-2v-3" />
                </svg>
                <div class="u-sub">Tap to upload</div>
              </div>
            </div>
          </div>
        </section>

        <section class="card">
          <div class="card-head">
            <div class="card-title" data-i18n="m-scanner-title">Barcode Scanner</div>
            <button class="icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2">
                <circle cx="12" cy="12" r="3" />
                <path
                  d="M19.4 15a1.7 1.7 0 00.3 1.8 2 2 0 01-2.8 2.8 1.7 1.7 0 00-1.8-.3 1.7 1.7 0 00-1 1.5 2 2 0 01-4 0 1.7 1.7 0 00-1-1.5 1.7 1.7 0 00-1.8.3 2 2 0 01-2.8-2.8 1.7 1.7 0 00.3-1.8 1.7 1.7 0 00-1.5-1 2 2 0 010-4 1.7 1.7 0 001.5-1 1.7 1.7 0 00-.3-1.8 2 2 0 012.8-2.8 1.7 1.7 0 001.8.3 1.7 1.7 0 001-1.5 2 2 0 014 0 1.7 1.7 0 001 1.5 1.7 1.7 0 001.8-.3 2 2 0 012.8 2.8 1.7 1.7 0 00-.3 1.8 1.7 1.7 0 001.5 1 2 2 0 010 4 1.7 1.7 0 00-1.5 1z" />
              </svg></button>
          </div>
          <div class="card-body">
            <div class="scanner">
              <div class="corner tl"></div>
              <div class="corner tr"></div>
              <div class="corner bl"></div>
              <div class="corner br"></div>
              <div class="laser"></div>
              <svg width="42" height="42" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.35)"
                stroke-width="1.5">
                <path d="M3 7h2M3 17h2M19 7h2M19 17h2M7 4v2M17 4v2M7 20v-2M17 20v-2M4 12h16" />
              </svg>
            </div>
            <div class="dim" style="font-size:11.5px;text-align:center;margin-top:8px" data-i18n="m-scan-hint">Can't
              scan? Enter barcode manually.</div>
            <button class="btn" style="width:100%;justify-content:center;margin-top:10px"
              onclick="openSheet('sheet-manual')">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="4" y="4" width="16" height="16" rx="2" />
                <path d="M8 4v16M12 4v16M16 4v16" />
              </svg>
              <span data-i18n="m-scan-manual">Scan Manually</span>
            </button>
          </div>
        </section>

        <section class="card">
          <div class="card-head">
            <div class="card-title" data-i18n="card-products">Products</div>
            <button class="btn link small" onclick="openSheet('sheet-product-pick')"><svg width="12" height="12"
                viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
                <path d="M12 5v14M5 12h14" />
              </svg>Add</button>
          </div>
          <div class="card-body" id="m-product-list"></div>
        </section>

        <section class="card">
          <div class="card-head">
            <div class="card-title">Additional Costs</div>
            <button class="btn link small" onclick="openCostSheet()"><svg width="12" height="12" viewBox="0 0 24 24"
                fill="none" stroke="currentColor" stroke-width="2.4">
                <path d="M12 5v14M5 12h14" />
              </svg>Add Cost</button>
          </div>
          <div class="card-body" id="m-cost-list"></div>
        </section>

        <section class="card">
          <div class="card-head">
            <div class="card-title">Installment Plan</div>
            <button class="btn link small" onclick="openSheet('sheet-plan-config')"
              data-i18n="m-plan-edit">Edit</button>
          </div>
          <div class="card-body">
            <div class="m-row2">
              <div class="ins-stat" style="padding:10px 12px">
                <div class="lbl">Installments</div>
                <div class="val num" style="font-size:17px" id="m-plan-n-dsp">3</div>
              </div>
              <div class="ins-stat" style="padding:10px 12px">
                <div class="lbl">Start</div>
                <div class="val num" style="font-size:17px" id="m-plan-start-dsp">12/01/2023</div>
              </div>
            </div>
            <div class="ins-stat primary" style="margin-top:10px;padding:10px 12px">
              <div class="lbl" data-i18n="m-per-inst">Per-Installment Payment</div>
              <div class="val num" id="m-per-inst">$0.00</div>
            </div>
            <div style="margin-top:10px;border:1px solid var(--border);border-radius:12px;overflow:hidden"
              id="m-plan-rows"></div>
          </div>
        </section>

        <section class="card">
          <div class="card-body">
            <div class="eyebrow" style="font-size:10px;letter-spacing:.14em;color:var(--text-dim);margin-bottom:6px"
              data-i18n="m-summary-title">Invoice Summary</div>
            <div class="mobile-totals">
              <div class="row"><span class="l">Subtotal</span><span class="num" id="m-t-subtotal">$0.00</span></div>
              <div class="row"><span class="l">Charges</span><span class="num" style="color:var(--success)"
                  id="m-t-charges">+$0.00</span></div>
              <div class="row"><span class="l">Discounts</span><span class="num" style="color:var(--danger)"
                  id="m-t-disc">−$0.00</span></div>
              <div class="row"><span class="l">Tax (<span id="m-t-tax-rate">5</span>%)</span><span class="num"
                  id="m-t-tax">+$0.00</span></div>
              <div class="row"><span class="l">− Down Payment</span><span class="num" style="color:var(--danger)"
                  id="m-t-dp">−$0.00</span></div>
              <div class="grand">
                <div>
                  <div class="g-lbl">Balance to Finance</div>
                  <div class="g-amt num" id="m-t-balance">$0.00</div>
                </div>
                <div style="text-align:right">
                  <div class="g-lbl">Invoice Total</div>
                  <div class="num" style="font-weight:700" id="m-t-total">$0.00</div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <div class="mobile-footer">
        <button class="btn">Cancel</button>
        <button class="btn primary" style="justify-content:center">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M5 12l5 5 9-11" />
          </svg>
          Submit Invoice
        </button>
      </div>
    </div>
  </div>

