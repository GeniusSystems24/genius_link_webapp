@page "/create-sale-invoice"
@inject DemoDataService Demo
@inject NavigationManager Navigation

<PageTitle>Create Sale Invoice</PageTitle>
<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/app.css" />
    <link rel="stylesheet" href="assets/css/create-sale-invoice.css" />
</HeadContent>

<Topbar />

<div class="desktop-wrap">
    <main class="page">
        <div class="page-head">
            <div>
                <div class="eyebrow">New Transaction - @SaleTypeLabel Sale</div>
                <h1>Create Sale Invoice</h1>
                <div class="sub">Record a new sale, capture payment terms, and generate an installment plan.</div>
            </div>
            <div><button class="btn ghost">Save draft</button></div>
        </div>

        <section class="card">
            <div class="card-head"><div class="card-title">Sale Type</div></div>
            <div class="card-body">
                <div class="sale-type">
                    @foreach (var type in SaleTypes)
                    {
                        <button class="@(SaleType == type.Value ? "active" : null)" @onclick="() => SaleType = type.Value">@type.Label</button>
                    }
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-head"><div><div class="card-title">Transaction Details</div><div class="card-sub">Invoice identifiers, customer account and payment terms.</div></div></div>
            <div class="card-body">
                <div class="form-grid">
                    <div class="field"><label>Currency</label><select class="select" @bind="Currency">@foreach (var item in Seed.Currencies) { <option>@item</option> }</select></div>
                    <div class="field"><label>Store</label><select class="select" @bind="Store">@foreach (var item in Seed.Stores) { <option>@item</option> }</select></div>
                    <div class="field"><label>Date Posted</label><input class="input" @bind="DatePosted" /></div>
                    <div class="field"><label>Customer Account</label><select class="select" @bind="CustomerId">@foreach (var customer in Seed.Customers) { <option value="@customer.Id">@customer.Name (#@customer.Id)</option> }</select></div>
                    <div class="field"><label>Cash Account (A/R)</label><input class="input" value="Accounts Receivable - Customers (1200-01)" disabled /></div>
                    <div class="field"><label>Reference</label><input class="input mono" @bind="Reference" /></div>
                    <div class="field"><label>Has Down Payment</label><button class="@SwitchClass" @onclick="ToggleDownPayment"><div class="switch-track"><div class="switch-thumb"></div></div><span>@(HasDownPayment ? "Enabled" : "Disabled")</span></button></div>
                    @if (HasDownPayment)
                    {
                        <div class="field"><label>Down Payment Cash / Bank Account</label><select class="select" @bind="DownPaymentAccount">@foreach (var item in Seed.DownPaymentAccounts) { <option>@item</option> }</select></div>
                        <div class="field"><label>Down Payment Amount</label><input class="input mono" @bind="DownPaymentAmount" /></div>
                    }
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-head"><div class="card-title">Additional Info</div></div>
            <div class="card-body">
                <div class="form-grid" style="grid-template-columns:2fr 1fr">
                    <div class="field"><label>Description</label><textarea class="textarea" placeholder="Internal notes or specific customer instructions..."></textarea></div>
                    <div class="field"><label>Attachments</label><div class="upload">@UiIcons.File <div class="u-title">Click to upload files</div><div class="u-sub">PDF, PNG, JPG up to 10 MB</div></div></div>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-head"><div class="card-title">Products</div><button class="btn link" @onclick="() => ActiveSheetId = ProductSheetId">@UiIcons.Add <span>Add Product</span></button></div>
            <div class="card-body" style="padding:8px 10px 10px">
                <div class="thead"><div>Product Name</div><div>SKU</div><div>Qty</div><div>Unit Price</div><div>Line Total</div><div></div></div>
                @foreach (var product in Products)
                {
                    <div class="trow">
                        <div class="pname"><div class="pthumb">@product.Icon</div><div><div class="pt">@product.Name</div><div class="ps">@product.Sub</div></div></div>
                        <div class="mono">@product.Sku</div>
                        <div class="step"><button @onclick="() => ChangeProductQuantity(product.Id, -1)">-</button><input class="input num" value="@product.Quantity" readonly /><button @onclick="() => ChangeProductQuantity(product.Id, 1)">+</button></div>
                        <div class="num">@UiFormat.Money(product.Price)</div>
                        <div class="num total-cell">@UiFormat.Money(ProductLineTotal(product))</div>
                        <div class="row-actions"><button class="icon-btn" @onclick="() => RemoveProduct(product.Id)">@UiIcons.Refund</button></div>
                    </div>
                }
            </div>
        </section>

        <section class="card">
            <div class="card-head"><div><div class="card-title">Additional Costs & Discounts</div><div class="card-sub">Line-item charges and discounts.</div></div><button class="btn link" @onclick="() => ActiveSheetId = CostSheetId">@UiIcons.Add <span>Add Cost</span></button></div>
            <div class="card-body" style="padding:8px 10px 10px">
                <div class="costs-head"><div>Description</div><div>Type</div><div>Rate / Basis</div><div>Amount</div><div></div></div>
                @foreach (var cost in Costs)
                {
                    <div class="cost-row">
                        <div>@cost.Description</div>
                        <div><span class="@CostPill(cost)">@cost.Type</span></div>
                        <div>@cost.Value@(cost.Mode == "percent" ? "%" : string.Empty)</div>
                        <div class="num">@SignedMoney(CostAmount(cost))</div>
                        <div class="row-actions"><button class="icon-btn" @onclick="() => RemoveCost(cost.Id)">@UiIcons.Refund</button></div>
                    </div>
                }
            </div>
        </section>

        <section class="card">
            <div class="card-head"><div class="card-title">Tax</div></div>
            <div class="card-body">
                <div class="form-grid" style="grid-template-columns:1fr 1fr 1fr 1fr">
                    <div class="field"><label>Tax Scheme</label><select class="select" @bind="TaxScheme"><option value="exclusive">Tax exclusive (added)</option><option value="inclusive">Tax inclusive (built-in)</option><option value="none">No tax</option></select></div>
                    <div class="field"><label>Tax Rate (%)</label><input class="input num" @bind="TaxRate" /></div>
                    <div class="field"><label>Tax Basis</label><input class="input" value="Subtotal - Discounts" disabled /></div>
                    <div class="field"><label>Tax Amount</label><input class="input mono" value="@UiFormat.Money(TaxAmount)" disabled /></div>
                </div>
            </div>
        </section>

        <section class="card">
            <div class="card-head"><div><div class="card-title">Installment Plan</div><div class="card-sub">Payment schedule for the balance remaining after down payment.</div></div><button class="btn link" @onclick="() => ActiveSheetId = PlanSheetId">Edit</button></div>
            <div class="card-body">
                <div class="ins-summary">
                    <div class="ins-stat"><div class="lbl">Invoice Total</div><div class="val num">@UiFormat.Money(InvoiceTotal)</div></div>
                    <div class="ins-stat warn"><div class="lbl">Down Payment</div><div class="val num">@SignedMoney(-AppliedDownPayment)</div></div>
                    <div class="ins-stat primary"><div class="lbl">Installment Base</div><div class="val num">@UiFormat.Money(BalanceToFinance)</div></div>
                </div>
                <div class="plan-table">
                    <div class="plan-thead"><div>#</div><div>Due Date</div><div>Amount</div><div>Status</div><div></div></div>
                    @foreach (var row in PlanRows)
                    {
                        <div class="plan-row"><div>@row.Number</div><div>@row.DueDate</div><div class="num">@UiFormat.Money(row.Amount)</div><div><span class="pill neutral">Pending</span></div><div></div></div>
                    }
                </div>
                <div class="dim" style="font-size:11.5px;margin-top:8px">The final installment absorbs any rounding remainder.</div>
            </div>
        </section>

        <section class="card">
            <div class="totals">
                <div class="note"><strong>Accounting flow.</strong> Posting this invoice will debit Accounts Receivable and credit revenue, tax, and payment accounts.</div>
                <dl>
                    <dt>Subtotal (net of line discounts)</dt><dd class="num">@UiFormat.Money(ProductNet)</dd>
                    <dt>Additional Charges</dt><dd class="num pos">@SignedMoney(ChargeTotal)</dd>
                    <dt>Discounts</dt><dd class="num neg">@SignedMoney(-DiscountTotal)</dd>
                    <dt>Taxable Net</dt><dd class="num">@UiFormat.Money(TaxableNet)</dd>
                    <dt>Tax (@TaxRate%)</dt><dd class="num pos">@SignedMoney(TaxAmount)</dd>
                    <div class="divider"></div>
                    <dt>Invoice Total</dt><dd class="num">@UiFormat.Money(InvoiceTotal)</dd>
                    <dt>Down Payment</dt><dd class="num neg">@SignedMoney(-AppliedDownPayment)</dd>
                    <div class="divider"></div>
                    <div class="grand"><dt>Balance to Finance</dt><dd class="num">@UiFormat.Money(BalanceToFinance)</dd></div>
                </dl>
            </div>
        </section>
    </main>
    <div class="page-footer"><button class="btn ghost" @onclick="Cancel">Cancel</button><button class="btn primary" @onclick="Submit">@UiIcons.Check <span>Submit Sale</span></button></div>
</div>

<div class="mobile-wrap">
    <div class="mobile-frame">
        <div class="mobile-topbar"><button class="icon-btn">@UiIcons.View</button><div><div class="t-eyebrow">New Transaction</div><h1>Create Invoice</h1></div><button class="icon-btn">@UiIcons.More</button></div>
        <div class="mobile-body">
            <div class="mobile-sale-type">@foreach (var type in SaleTypes) { <button class="@(SaleType == type.Value ? "active" : null)" @onclick="() => SaleType = type.Value">@type.Label</button> }</div>
            <section class="card"><div class="card-head"><div class="card-title">Transaction Details</div></div><div class="card-body"><div class="m-field"><label>Customer Account</label><button class="m-picker" @onclick="() => ActiveSheetId = CustomerSheetId"><span>@SelectedCustomer.Name (#@SelectedCustomer.Id)</span>@UiIcons.View</button></div><div class="m-row2"><div class="m-field"><label>Reference</label><input class="input mono" @bind="Reference" /></div><div class="m-field"><label>Date Posted</label><input class="input" @bind="DatePosted" /></div></div><div class="m-field"><label>Down Payment Amount</label><input class="input mono" @bind="DownPaymentAmount" /></div></div></section>
            <section class="card"><div class="card-head"><div class="card-title">Products</div><button class="btn link small" @onclick="() => ActiveSheetId = ProductSheetId">@UiIcons.Add Add</button></div><div class="card-body">@foreach (var product in Products) { <div class="m-prod"><div class="m-prod-icon">@product.Icon</div><div><div style="font-weight:700">@product.Name</div><div style="font-size:12px;color:var(--text-muted)">Qty @product.Quantity - @UiFormat.Money(product.Price) ea</div></div><div style="font-weight:700">@UiFormat.Money(ProductLineTotal(product))</div></div> }</div></section>
            <section class="card"><div class="card-head"><div class="card-title">Installment Plan</div><button class="btn link small" @onclick="() => ActiveSheetId = PlanSheetId">Edit</button></div><div class="card-body"><div class="m-row2"><div class="ins-stat" style="padding:10px 12px"><div class="lbl">Installments</div><div class="val num" style="font-size:17px">@InstallmentCount</div></div><div class="ins-stat" style="padding:10px 12px"><div class="lbl">Start</div><div class="val num" style="font-size:17px">@PlanStart</div></div></div><div class="ins-stat primary" style="margin-top:10px;padding:10px 12px"><div class="lbl">Per-Installment Payment</div><div class="val num">@UiFormat.Money(PerInstallment)</div></div></div></section>
            <section class="card"><div class="card-body"><div class="eyebrow" style="font-size:10px;letter-spacing:.14em;color:var(--text-dim);margin-bottom:6px">Invoice Summary</div><div class="mobile-totals"><div class="row"><span class="l">Subtotal</span><span class="num">@UiFormat.Money(ProductNet)</span></div><div class="row"><span class="l">Charges</span><span class="num" style="color:var(--success)">@SignedMoney(ChargeTotal)</span></div><div class="row"><span class="l">Discounts</span><span class="num" style="color:var(--danger)">@SignedMoney(-DiscountTotal)</span></div><div class="row"><span class="l">Tax</span><span class="num">@SignedMoney(TaxAmount)</span></div><div class="grand"><div><div class="g-lbl">Balance to Finance</div><div class="g-amt num">@UiFormat.Money(BalanceToFinance)</div></div><div style="text-align:right"><div class="g-lbl">Invoice Total</div><div class="num" style="font-weight:700">@UiFormat.Money(InvoiceTotal)</div></div></div></div></div></section>
        </div>
        <div class="mobile-footer"><button class="btn" @onclick="Cancel">Cancel</button><button class="btn primary" style="justify-content:center" @onclick="Submit">@UiIcons.Check Submit Invoice</button></div>
    </div>
</div>

<BottomSheets @bind-ActiveSheetId="ActiveSheetId">
    <BottomSheet Id="@ProductSheetId" Title="Select Product" Subtitle="Search the catalog or scan a barcode">
        <ChildContent>
            <div class="list-pick">
                @foreach (var item in Seed.Catalog)
                {
                    <button @onclick="() => AddProduct(item)"><span style="font-weight:700">@item.Name</span><span>@item.Sub - @UiFormat.Money(item.Price)</span></button>
                }
            </div>
        </ChildContent>
    </BottomSheet>
    <BottomSheet Id="@CustomerSheetId" Title="Select Customer">
        <ChildContent><div class="list-pick">@foreach (var customer in Seed.Customers) { <button @onclick="() => SelectCustomer(customer.Id)"><span style="font-weight:700">@customer.Name</span><span>@customer.Sub</span></button> }</div></ChildContent>
    </BottomSheet>
    <BottomSheet Id="@CostSheetId" Title="Add Cost" Subtitle="Add a common charge or discount">
        <ChildContent><div class="list-pick"><button @onclick="AddDeliveryCost"><span style="font-weight:700">Delivery Fee</span><span>Fixed $8.00 charge</span></button><button @onclick="AddPromotionalDiscount"><span style="font-weight:700">Promotional Discount</span><span>5% discount</span></button></div></ChildContent>
    </BottomSheet>
    <BottomSheet Id="@PlanSheetId" Title="Installment Plan" Subtitle="Configure schedule">
        <ChildContent>
            <div class="field"><label>Number of Installments</label><input class="input" type="number" min="1" max="36" @bind="InstallmentCount" /></div>
            <div class="field"><label>Start Date</label><input class="input" @bind="PlanStart" /></div>
            <div class="field"><label>Frequency</label><select class="select" @bind="PlanFrequency"><option>Monthly</option><option>Bi-weekly</option><option>Weekly</option><option>Quarterly</option></select></div>
        </ChildContent>
        <FooterContent><button class="btn" @onclick="CloseSheets">Cancel</button><button class="btn primary" style="justify-content:center" @onclick="CloseSheets">Done</button></FooterContent>
    </BottomSheet>
</BottomSheets>

@code {
    private const string ProductSheetId = "sheet-product-pick";
    private const string CustomerSheetId = "sheet-customer";
    private const string CostSheetId = "sheet-cost";
    private const string PlanSheetId = "sheet-plan-config";

    private CreateInvoiceSeed Seed = default!;
    private List<CreateProductDraft> Products = [];
    private List<CreateCostDraft> Costs = [];
    private string SaleType { get; set; } = "installment";
    private string Currency { get; set; } = string.Empty;
    private string Store { get; set; } = string.Empty;
    private string CustomerId { get; set; } = string.Empty;
    private string Reference { get; set; } = "INV-2023-007";
    private string DatePosted { get; set; } = "11/01/2023";
    private bool HasDownPayment { get; set; } = true;
    private string DownPaymentAccount { get; set; } = string.Empty;
    private decimal DownPaymentAmount { get; set; } = 30m;
    private string TaxScheme { get; set; } = "exclusive";
    private decimal TaxRate { get; set; } = 5m;
    private int InstallmentCount { get; set; }
    private string PlanStart { get; set; } = string.Empty;
    private string PlanFrequency { get; set; } = "Monthly";
    private string? ActiveSheetId { get; set; }

    private static readonly IReadOnlyList<(string Label, string Value)> SaleTypes = [("Cash", "cash"), ("Credit", "credit"), ("Advance", "advance"), ("Installment", "installment")];

    protected override void OnInitialized()
    {
        Seed = Demo.GetCreateInvoiceSeed();
        Products = Seed.Products.ToList();
        Costs = Seed.Costs.ToList();
        Currency = Seed.Currencies[0];
        Store = Seed.Stores[0];
        CustomerId = Seed.Customers[0].Id;
        DownPaymentAccount = Seed.DownPaymentAccounts[0];
        InstallmentCount = Seed.Plan.InstallmentCount;
        PlanStart = Seed.Plan.StartDate;
        PlanFrequency = Seed.Plan.Frequency;
    }

    private CustomerPickerItem SelectedCustomer => Seed.Customers.First(item => item.Id == CustomerId);
    private string SaleTypeLabel => SaleTypes.First(item => item.Value == SaleType).Label;
    private string SwitchClass => HasDownPayment ? "switch on" : "switch";
    private decimal ProductGross => Products.Sum(product => product.Price * product.Quantity);
    private decimal ProductDiscount => Products.Sum(ProductDiscountAmount);
    private decimal ProductNet => Math.Max(0, ProductGross - ProductDiscount);
    private decimal ChargeTotal => Costs.Where(cost => cost.Type == "charge").Sum(CostAmount);
    private decimal DiscountTotal => Costs.Where(cost => cost.Type == "discount").Sum(cost => Math.Abs(CostAmount(cost)));
    private decimal TaxableNet => Math.Max(0, ProductNet + ChargeTotal - DiscountTotal);
    private decimal TaxAmount => TaxScheme == "none" ? 0m : Math.Round(TaxableNet * TaxRate / 100m, 2, MidpointRounding.AwayFromZero);
    private decimal InvoiceTotal => TaxScheme == "inclusive" ? TaxableNet : TaxableNet + TaxAmount;
    private decimal AppliedDownPayment => HasDownPayment ? Math.Min(DownPaymentAmount, InvoiceTotal) : 0m;
    private decimal BalanceToFinance => Math.Max(0, InvoiceTotal - AppliedDownPayment);
    private decimal PerInstallment => InstallmentCount <= 0 ? BalanceToFinance : Math.Round(BalanceToFinance / InstallmentCount, 2, MidpointRounding.AwayFromZero);

    private IReadOnlyList<PlanRow> PlanRows => Enumerable.Range(1, Math.Max(1, InstallmentCount))
        .Select(number => new PlanRow(number, $"{PlanStart} + {number - 1} {PlanFrequency}", number == InstallmentCount ? BalanceToFinance - (PerInstallment * (InstallmentCount - 1)) : PerInstallment))
        .ToArray();

    private decimal ProductDiscountAmount(CreateProductDraft product)
    {
        var gross = product.Price * product.Quantity;
        return product.DiscountType == "percent" ? Math.Round(gross * product.DiscountValue / 100m, 2, MidpointRounding.AwayFromZero) : Math.Min(product.DiscountValue, gross);
    }

    private decimal ProductLineTotal(CreateProductDraft product)
    {
        return Math.Max(0, product.Price * product.Quantity - ProductDiscountAmount(product));
    }

    private decimal CostAmount(CreateCostDraft cost)
    {
        var amount = cost.Mode == "percent" ? Math.Round(ProductNet * cost.Value / 100m, 2, MidpointRounding.AwayFromZero) : cost.Value;
        return cost.Type == "discount" ? -Math.Abs(amount) : amount;
    }

    private void ToggleDownPayment()
    {
        HasDownPayment = !HasDownPayment;
    }

    private void ChangeProductQuantity(int productId, int delta)
    {
        Products = Products.Select(product => product.Id == productId ? product with { Quantity = Math.Max(1, product.Quantity + delta) } : product).ToList();
    }

    private void RemoveProduct(int productId)
    {
        Products.RemoveAll(product => product.Id == productId);
    }

    private void AddProduct(CatalogItem item)
    {
        var nextId = Products.Count == 0 ? 1 : Products.Max(product => product.Id) + 1;
        Products.Add(new CreateProductDraft(nextId, item.Id, item.Name, item.Sub, item.Icon, item.Price, 1, "amount", 0m, string.Empty));
        ActiveSheetId = null;
    }

    private void SelectCustomer(string customerId)
    {
        CustomerId = customerId;
        ActiveSheetId = null;
    }

    private void AddCost(string description, string type, string mode, decimal value)
    {
        var nextId = Costs.Count == 0 ? 1 : Costs.Max(cost => cost.Id) + 1;
        Costs.Add(new CreateCostDraft(nextId, description, type, mode, value));
        ActiveSheetId = null;
    }

    private void AddDeliveryCost()
    {
        AddCost("Delivery Fee", "charge", "fixed", 8m);
    }

    private void AddPromotionalDiscount()
    {
        AddCost("Promotional Discount", "discount", "percent", 5m);
    }

    private void RemoveCost(int costId)
    {
        Costs.RemoveAll(cost => cost.Id == costId);
    }

    private void CloseSheets()
    {
        ActiveSheetId = null;
    }

    private void Submit()
    {
        Navigation.NavigateTo(SaleType == "cash" ? "/sale-invoice-details-cash" : "/sale-invoice-details");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/invoice-list");
    }

    private static string CostPill(CreateCostDraft cost) => cost.Type == "charge" ? "pill success" : "pill danger";
    private static string SignedMoney(decimal amount) => amount < 0 ? "-" + UiFormat.Money(Math.Abs(amount)) : "+" + UiFormat.Money(amount);
    private sealed record PlanRow(int Number, string DueDate, decimal Amount);
}
