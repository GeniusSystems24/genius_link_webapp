@page "/customer-profile"

<PageTitle>Customer Profile</PageTitle>
<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/app.css" />
    <link rel="stylesheet" href="assets/css/customer-profile.css" />
</HeadContent>

<!-- Topbar -->
<div data-component="topbar"
     data-brand-href="/invoice-list"
     data-crumbs='[{"label":"Customers","href":"/invoice-list","key":"nav-customers"},{"label":"Alex Thompson"}]'></div>

<!-- =================== DESKTOP =================== -->
<div class="desktop-wrap">
<main class="page">

  <!-- Hero -->
  <div class="hero">
    <div class="hero-banner"></div>
    <div class="hero-body">
      <div class="hero-left">
        <div class="avatar" id="cust-initial">A</div>
        <div class="hero-info">
          <div class="hero-name" id="cust-name">Alex Thompson</div>
          <div class="hero-sub">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span id="cust-email">alex.thompson@@example.com</span>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.87 1.18 2 2 0 012.85 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L7.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
            <span id="cust-phone">+1 555 010 2233</span>
            <span style="color:var(--text-dim)">·</span>
            <span data-i18n="since-label">Customer since</span> <strong style="color:var(--text)" id="cust-since">Jan 2021</strong>
          </div>
          <div class="hero-tags" id="hero-tags">
            <span class="pill neutral" data-i18n="pill-retail">Retail</span>
            <span class="pill gold">★ Gold Member</span>
            <span class="pill primary" data-i18n="pill-active">Active</span>
            <span class="pill neutral" id="cust-id-pill">#F-062</span>
          </div>
        </div>
      </div>
      <div class="hero-actions">
        <button class="btn small"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07"/></svg><span data-i18n="btn-call">Call</span></button>
        <button class="btn small"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg><span data-i18n="btn-email">Email</span></button>
        <a href="/create-sale-invoice" class="btn small primary"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg><span data-i18n="btn-new-invoice">New Invoice</span></a>
        <a href="/record-payment" class="btn small"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5 9-11"/></svg><span data-i18n="btn-record-payment">Record Payment</span></a>
      </div>
    </div>
  </div>

  <!-- Stats strip -->
  <div id="customer-stats"></div>

  <!-- Two col -->
  <div class="two-col">
    <!-- Left -->
    <div>

      <!-- Invoice history -->
      <div class="card">
        <div class="card-head">
          <div class="card-title" data-i18n="card-inv-history">Invoice History</div>
          <div style="display:flex;gap:8px;align-items:center">
            <span class="pill neutral"><span id="inv-count">14</span> <span data-i18n="invoices-count">invoices</span></span>
            <a href="/invoice-list" class="btn link small" data-i18n="btn-view-all">View All</a>
          </div>
        </div>
        <div class="inv-thead">
          <div class="th" data-i18n="th-ref">Reference</div>
          <div class="th" data-i18n="th-date">Date</div>
          <div class="th" data-i18n="th-type">Type</div>
          <div class="th" data-i18n="th-total">Total</div>
          <div class="th" data-i18n="th-balance">Balance</div>
          <div class="th" data-i18n="th-status">Status</div>
        </div>
        <div id="inv-history-rows"></div>
      </div>

      <!-- Payment timeline -->
      <div class="card">
        <div class="card-head"><div class="card-title" data-i18n="card-pay-history">Payment History</div></div>
        <div class="card-body" style="padding-top:12px">
          <div id="payment-history-list"></div>
        </div>
      </div>

      <!-- Notes -->
      <div class="card">
        <div class="card-head"><div class="card-title" data-i18n="card-notes">Internal Notes</div><button class="btn small primary" data-i18n="btn-add-note">+ Add Note</button></div>
        <div class="card-body" style="padding-top:12px">
          <div id="notes-list"></div>
          <textarea class="note-area" style="margin-top:14px" data-i18n-ph="note-ph" placeholder="Write a new note…"></textarea>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
      <!-- contact -->
      <div class="sidebar-card">
        <div class="sc-head"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"/></svg><span data-i18n="card-contact">Contact Info</span></div>
        <div class="sc-body" id="contact-info-rows"></div>
      </div>
      <!-- balance -->
      <div class="sidebar-card">
        <div class="sc-head"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg><span data-i18n="card-account-balance">Account Balance</span></div>
        <div class="sc-body">
          <div id="balance-info-rows"></div>
          <div style="margin-top:10px"><a href="/record-payment" class="btn primary" style="width:100%;justify-content:center">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5 9-11"/></svg>
            <span data-i18n="btn-record-payment">Record Payment</span>
          </a></div>
        </div>
      </div>
      <!-- loyalty -->
      <div class="sidebar-card">
        <div class="sc-head"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg><span data-i18n="card-loyalty">Loyalty Program</span></div>
        <div class="sc-body">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
            <span class="pill gold">★ <span id="loyalty-tier">Gold</span></span>
            <span style="font-size:12px;color:var(--text-muted)" id="loyalty-progress">1,284 / 2,000 pts</span>
          </div>
          <div class="loyalty-track"><div class="loyalty-fill" id="loyalty-fill" style="width:64%"></div></div>
          <div class="loyalty-labels"><span data-i18n="tier-silver">Silver</span><span data-i18n="tier-gold">Gold ★</span><span data-i18n="tier-platinum">Platinum</span></div>
          <div style="margin-top:12px;font-size:12.5px;color:var(--text-muted)" data-i18n="loyalty-note">716 more points to reach Platinum tier.</div>
        </div>
      </div>
      <!-- quick actions -->
      <div class="sidebar-card">
        <div class="sc-head" data-i18n="card-actions">Quick Actions</div>
        <div class="sc-body" style="display:flex;flex-direction:column;gap:8px">
          <button class="btn" style="width:100%;justify-content:flex-start"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2"/></svg><span data-i18n="btn-send-reminder">Send Payment Reminder</span></button>
          <button class="btn" style="width:100%;justify-content:flex-start"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg><span data-i18n="btn-export-statement">Export Statement</span></button>
          <button class="btn" style="width:100%;justify-content:flex-start"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg><span data-i18n="btn-view-invoices">View All Invoices</span></button>
          <button class="btn danger" style="width:100%;justify-content:flex-start"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M6 6l12 12"/></svg><span data-i18n="btn-deactivate">Deactivate Customer</span></button>
        </div>
      </div>
    </div>
  </div>
</main>
</div>

<!-- =================== MOBILE =================== -->
<div class="mobile-wrap">
  <div class="mobile-frame">
    <div class="m-topbar">
      <button style="appearance:none;border:0;background:transparent;color:var(--text-muted);cursor:pointer;padding:4px"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg></button>
      <div style="text-align:center"><div class="m-eyebrow" data-i18n="nav-customers">Customers</div><h1 id="m-cust-name">Alex Thompson</h1></div>
      <button class="icon-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button>
    </div>
    <div class="m-body">
      <div class="m-hero">
        <div class="m-banner"></div>
        <div class="m-av-row">
          <div class="m-avatar" id="m-cust-initial">A</div>
          <div style="display:flex;gap:6px;padding-top:6px">
            <button style="appearance:none;border:1px solid var(--border);background:var(--surface);border-radius:8px;color:var(--text-muted);width:30px;height:30px;display:grid;place-items:center;cursor:pointer"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2"/></svg></button>
            <button style="appearance:none;border:1px solid var(--border);background:var(--surface);border-radius:8px;color:var(--text-muted);width:30px;height:30px;display:grid;place-items:center;cursor:pointer"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12"/></svg></button>
          </div>
        </div>
        <div class="m-info">
          <div class="m-name" id="m-cust-name-2">Alex Thompson</div>
          <div class="m-sub" id="m-cust-sub">alex.thompson@@example.com · +1 555 010 2233</div>
          <div class="m-tags">
            <span class="pill neutral" data-i18n="pill-retail">Retail</span>
            <span class="pill gold">★ Gold</span>
            <span class="pill primary" data-i18n="pill-active">Active</span>
          </div>
        </div>
      </div>

      <div class="m-stats-grid" id="m-customer-stats"></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
        <a href="/create-sale-invoice" class="btn primary" style="justify-content:center;font-size:13px"><span data-i18n="btn-new-invoice">New Invoice</span></a>
        <a href="/record-payment" class="btn" style="justify-content:center;font-size:13px"><span data-i18n="btn-record-payment">Record Payment</span></a>
      </div>

      <div class="m-card">
        <div class="m-card-head"><div class="m-card-title" data-i18n="card-inv-history">Invoice History</div><span class="pill neutral" id="m-inv-count">14</span></div>
        <div class="m-card-body" id="m-inv-history-rows"></div>
      </div>

      <div class="m-card">
        <div class="m-card-head"><div class="m-card-title" data-i18n="card-contact">Contact Info</div></div>
        <div class="m-card-body" id="m-contact-info-rows"></div>
      </div>

      <div class="m-card">
        <div class="m-card-head"><div class="m-card-title" data-i18n="card-loyalty">Loyalty</div><span class="pill gold">★ Gold</span></div>
        <div class="m-card-body">
          <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);margin-bottom:6px"><span id="m-loyalty-progress">1,284 pts</span><span data-i18n="tier-platinum">Platinum: 2,000</span></div>
          <div class="loyalty-track"><div class="loyalty-fill" id="m-loyalty-fill" style="width:64%"></div></div>
          <div style="font-size:11.5px;color:var(--text-dim);margin-top:6px" data-i18n="loyalty-note">716 more points to reach Platinum tier.</div>
        </div>
      </div>
    </div>

    <div class="mobile-footer">
      <button class="btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16"/></svg><span data-i18n="btn-statement">Statement</span></button>
      <a href="/record-payment" class="btn primary" style="justify-content:center">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12l5 5 9-11"/></svg>
        <span data-i18n="btn-record-payment">Record Payment</span>
      </a>
    </div>
  </div>
</div>

<script src="assets/js/theme.js"></script>
<script src="assets/js/view.js"></script>
<script src="assets/js/i18n.js"></script>
<script src="assets/js/format.js"></script>
<script src="assets/js/data-loader.js"></script>
<script src="assets/js/app-bootstrap.js"></script>
<script src="assets/js/components.js"></script>
<script src="assets/js/customer-profile.js"></script>
<script src="arabic-page-helper.js"></script>
