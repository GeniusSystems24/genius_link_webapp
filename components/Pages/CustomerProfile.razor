@page "/customer-profile"
@inject DemoDataService Demo

<PageTitle>Customer Profile</PageTitle>
<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/app.css" />
    <link rel="stylesheet" href="assets/css/customer-profile.css" />
</HeadContent>

<Topbar BrandHref="/invoice-list" Crumbs="Crumbs" />

<div class="desktop-wrap">
    <main class="page">
        <div class="hero">
            <div class="hero-banner"></div>
            <div class="hero-body">
                <div class="hero-left">
                    <div class="avatar">@Profile.Customer.Initial</div>
                    <div class="hero-info">
                        <div class="hero-name">@Profile.Customer.Name</div>
                        <div class="hero-sub">
                            @UiIcons.Mail <span>@Profile.Customer.Email</span>
                            @UiIcons.Phone <span>@Profile.Customer.Phone</span>
                            <span style="color:var(--text-dim)">-</span>
                            <span data-i18n="since-label">Customer since</span> <strong style="color:var(--text)">@Profile.Customer.Since</strong>
                        </div>
                        <div class="hero-tags">
                            <span class="pill neutral" data-i18n="pill-retail">@Profile.Customer.Segment</span>
                            <span class="pill gold">@Profile.Customer.Tier Member</span>
                            <span class="pill primary" data-i18n="pill-active">Active</span>
                            <span class="pill neutral">#@Profile.Customer.Id</span>
                        </div>
                    </div>
                </div>
                <div class="hero-actions">
                    <button class="btn small">@UiIcons.Phone <span data-i18n="btn-call">Call</span></button>
                    <button class="btn small">@UiIcons.Mail <span data-i18n="btn-email">Email</span></button>
                    <a href="/create-sale-invoice" class="btn small primary">@UiIcons.Add <span data-i18n="btn-new-invoice">New Invoice</span></a>
                    <a href="/record-payment" class="btn small">@UiIcons.Check <span data-i18n="btn-record-payment">Record Payment</span></a>
                </div>
            </div>
        </div>

        <StatsStrip Items="Stats" />

        <div class="two-col">
            <div>
                <div class="card">
                    <div class="card-head">
                        <div class="card-title" data-i18n="card-inv-history">Invoice History</div>
                        <div style="display:flex;gap:8px;align-items:center">
                            <span class="pill neutral">@Profile.Stats.TotalInvoices <span data-i18n="invoices-count">invoices</span></span>
                            <a href="/invoice-list" class="btn link small" data-i18n="btn-view-all">View All</a>
                        </div>
                    </div>
                    <div class="inv-thead">
                        <div class="th" data-i18n="th-ref">Reference</div>
                        <div class="th" data-i18n="th-date">Date</div>
                        <div class="th" data-i18n="th-type">Type</div>
                        <div class="th" data-i18n="th-total">Total</div>
                        <div class="th" data-i18n="th-balance">Balance</div>
                        <div class="th" data-i18n="th-status">Status</div>
                    </div>
                    @foreach (var invoice in Profile.History)
                    {
                        <div class="inv-row">
                            <InvoiceRow Item="invoice" Variant="InvoiceRowVariant.History" />
                        </div>
                    }
                </div>

                <div class="card">
                    <div class="card-head"><div class="card-title" data-i18n="card-pay-history">Payment History</div></div>
                    <div class="card-body" style="padding-top:12px">
                        <PaymentList Payments="Profile.Payments" />
                    </div>
                </div>

                <div class="card">
                    <div class="card-head"><div class="card-title" data-i18n="card-notes">Internal Notes</div><button class="btn small primary" data-i18n="btn-add-note">+ Add Note</button></div>
                    <div class="card-body" style="padding-top:12px">
                        <PaymentList Notes="Profile.Notes" />
                        <textarea class="note-area" style="margin-top:14px" data-i18n-ph="note-ph" placeholder="Write a new note..."></textarea>
                    </div>
                </div>
            </div>

            <div class="sidebar">
                <div class="sidebar-card">
                    <div class="sc-head">@UiIcons.User <span data-i18n="card-contact">Contact Info</span></div>
                    <div class="sc-body"><InfoRows Items="ContactInfoRows" /></div>
                </div>

                <div class="sidebar-card">
                    <div class="sc-head">@UiIcons.Card <span data-i18n="card-account-balance">Account Balance</span></div>
                    <div class="sc-body">
                        <InfoRows Items="BalanceRows" />
                        <div style="margin-top:10px">
                            <a href="/record-payment" class="btn primary" style="width:100%;justify-content:center">@UiIcons.Check <span data-i18n="btn-record-payment">Record Payment</span></a>
                        </div>
                    </div>
                </div>

                <div class="sidebar-card">
                    <div class="sc-head">@UiIcons.Reminder <span data-i18n="card-loyalty">Loyalty Program</span></div>
                    <div class="sc-body">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
                            <span class="pill gold">@Profile.Customer.Tier</span>
                            <span style="font-size:12px;color:var(--text-muted)">@Profile.Stats.LoyaltyPoints / @Profile.Stats.LoyaltyTarget pts</span>
                        </div>
                        <div class="loyalty-track"><div class="loyalty-fill" style="width:@Profile.Stats.LoyaltyProgressPct%"></div></div>
                        <div class="loyalty-labels"><span data-i18n="tier-silver">Silver</span><span data-i18n="tier-gold">Gold</span><span data-i18n="tier-platinum">Platinum</span></div>
                        <div style="margin-top:12px;font-size:12.5px;color:var(--text-muted)">@Profile.Stats.LoyaltyToNext more points to reach Platinum tier.</div>
                    </div>
                </div>

                <div class="sidebar-card">
                    <div class="sc-head" data-i18n="card-actions">Quick Actions</div>
                    <div class="sc-body" style="display:flex;flex-direction:column;gap:8px">
                        <button class="btn" style="width:100%;justify-content:flex-start">@UiIcons.Reminder <span data-i18n="btn-send-reminder">Send Payment Reminder</span></button>
                        <button class="btn" style="width:100%;justify-content:flex-start">@UiIcons.File <span data-i18n="btn-export-statement">Export Statement</span></button>
                        <a href="/invoice-list" class="btn" style="width:100%;justify-content:flex-start">@UiIcons.View <span data-i18n="btn-view-invoices">View All Invoices</span></a>
                        <button class="btn danger" style="width:100%;justify-content:flex-start">@UiIcons.Refund <span data-i18n="btn-deactivate">Deactivate Customer</span></button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="mobile-wrap">
    <div class="mobile-frame">
        <div class="m-topbar">
            <button style="appearance:none;border:0;background:transparent;color:var(--text-muted);cursor:pointer;padding:4px">@UiIcons.Menu</button>
            <div style="text-align:center"><div class="m-eyebrow" data-i18n="nav-customers">Customers</div><h1>@Profile.Customer.Name</h1></div>
            <button class="icon-btn">@UiIcons.More</button>
        </div>
        <div class="m-body">
            <div class="m-hero">
                <div class="m-banner"></div>
                <div class="m-av-row">
                    <div class="m-avatar">@Profile.Customer.Initial</div>
                    <div style="display:flex;gap:6px;padding-top:6px">
                        <button style="appearance:none;border:1px solid var(--border);background:var(--surface);border-radius:8px;color:var(--text-muted);width:30px;height:30px;display:grid;place-items:center;cursor:pointer">@UiIcons.Phone</button>
                        <button style="appearance:none;border:1px solid var(--border);background:var(--surface);border-radius:8px;color:var(--text-muted);width:30px;height:30px;display:grid;place-items:center;cursor:pointer">@UiIcons.Mail</button>
                    </div>
                </div>
                <div class="m-info">
                    <div class="m-name">@Profile.Customer.Name</div>
                    <div class="m-sub">@Profile.Customer.Email - @Profile.Customer.Phone</div>
                    <div class="m-tags">
                        <span class="pill neutral">@Profile.Customer.Segment</span>
                        <span class="pill gold">@Profile.Customer.Tier</span>
                        <span class="pill primary" data-i18n="pill-active">Active</span>
                    </div>
                </div>
            </div>

            <div class="m-stats-grid">
                @foreach (var stat in MobileStats)
                {
                    <div class="m-stat @stat.Tone"><div class="lbl">@stat.Label</div><div class="val">@stat.Value</div></div>
                }
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
                <a href="/create-sale-invoice" class="btn primary" style="justify-content:center;font-size:13px"><span data-i18n="btn-new-invoice">New Invoice</span></a>
                <a href="/record-payment" class="btn" style="justify-content:center;font-size:13px"><span data-i18n="btn-record-payment">Record Payment</span></a>
            </div>

            <div class="m-card">
                <div class="m-card-head"><div class="m-card-title" data-i18n="card-inv-history">Invoice History</div><span class="pill neutral">@Profile.Stats.TotalInvoices</span></div>
                <div class="m-card-body">
                    @foreach (var invoice in Profile.History)
                    {
                        <div class="m-inv-row"><InvoiceRow Item="invoice" Variant="InvoiceRowVariant.MobileHistory" /></div>
                    }
                </div>
            </div>

            <div class="m-card">
                <div class="m-card-head"><div class="m-card-title" data-i18n="card-contact">Contact Info</div></div>
                <div class="m-card-body"><InfoRows Items="ContactInfoRows" Mobile="true" /></div>
            </div>

            <div class="m-card">
                <div class="m-card-head"><div class="m-card-title" data-i18n="card-loyalty">Loyalty</div><span class="pill gold">@Profile.Customer.Tier</span></div>
                <div class="m-card-body">
                    <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-muted);margin-bottom:6px"><span>@Profile.Stats.LoyaltyPoints pts</span><span>Platinum: @Profile.Stats.LoyaltyTarget</span></div>
                    <div class="loyalty-track"><div class="loyalty-fill" style="width:@Profile.Stats.LoyaltyProgressPct%"></div></div>
                    <div style="font-size:11.5px;color:var(--text-dim);margin-top:6px">@Profile.Stats.LoyaltyToNext more points to reach Platinum tier.</div>
                </div>
            </div>
        </div>

        <div class="mobile-footer">
            <button class="btn">@UiIcons.File <span data-i18n="btn-statement">Statement</span></button>
            <a href="/record-payment" class="btn primary" style="justify-content:center">@UiIcons.Check <span data-i18n="btn-record-payment">Record Payment</span></a>
        </div>
    </div>
</div>

@code {
    private CustomerProfileData Profile = default!;
    private static readonly IReadOnlyList<BreadcrumbItem> Crumbs = [new("Customers", "/invoice-list", "nav-customers"), new("Alex Thompson")];

    protected override void OnInitialized()
    {
        Profile = Demo.GetCustomerProfile();
    }

    private IReadOnlyList<StatItem> Stats =>
    [
        new(Profile.Stats.TotalSpent, "success", "Total Spent", "stat-total-spent", "Lifetime value", "stat-lifetime"),
        new(Profile.Stats.TotalInvoices.ToString(), "primary", "Total Invoices", "stat-invoices", "All time", "stat-all-time"),
        new(Profile.Stats.Outstanding, "danger", "Outstanding", "stat-outstanding", "1 invoice open", "stat-open-invoices"),
        new(Profile.Stats.LoyaltyPoints.ToString(), "amber", "Loyalty Points", "stat-loyalty", $"{Profile.Customer.Tier} tier", "stat-tier")
    ];

    private IReadOnlyList<StatItem> MobileStats =>
    [
        new(Profile.Stats.TotalSpent, "success", "Total Spent"),
        new(Profile.Stats.TotalInvoices.ToString(), "primary", "Invoices"),
        new(Profile.Stats.Outstanding, "danger", "Outstanding"),
        new(Profile.Stats.LoyaltyPoints.ToString(), null, "Points")
    ];

    private IReadOnlyList<InfoRowItem> ContactInfoRows =>
    [
        new(Profile.Customer.Name, "Name", "k-name"),
        new(Profile.Customer.Id, "Customer ID", "k-id", Mono: true),
        new(Profile.Customer.Email, "Email", "k-email"),
        new(Profile.Customer.Phone, "Phone", "k-phone"),
        new(Profile.Customer.Segment, "Segment", "k-segment"),
        new(Profile.Customer.Since, "Member Since", "k-member-since")
    ];

    private IReadOnlyList<InfoRowItem> BalanceRows =>
    [
        new(Profile.Stats.Outstanding, "Outstanding", "k-outstanding", "danger"),
        new(Profile.Stats.TotalPaid, "Total Paid", "k-total-paid", "success"),
        new(Profile.Stats.Overdue, "Overdue", "k-overdue")
    ];
}
