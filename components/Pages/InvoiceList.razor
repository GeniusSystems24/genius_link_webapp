@page "/invoice-list"
@inject DemoDataService Demo
@inject NavigationManager Navigation

<PageTitle>Invoice List</PageTitle>
<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/app.css" />
    <link rel="stylesheet" href="assets/css/invoice-list.css" />
</HeadContent>

<Topbar BrandHref="/create-sale-invoice" Crumbs="Crumbs" />

<div class="desktop-wrap">
    <main class="page">
        <div class="page-head">
            <div>
                <h1 data-i18n="page-title">Sale Invoices</h1>
                <div class="sub" data-i18n="page-sub">All transactions across stores and sale types.</div>
            </div>
            <div style="display:flex;gap:8px">
                <button class="btn" @onclick="() => ActiveSheetId = FilterSheetId">@UiIcons.Filter <span data-i18n="btn-filter">Filters</span></button>
                <a href="/create-sale-invoice" class="btn primary">@UiIcons.Add <span data-i18n="btn-new-invoice">New Invoice</span></a>
            </div>
        </div>

        <StatsStrip Items="Stats" />

        <div class="filters">
            <div class="search-wrap">
                @UiIcons.Search
                <input @bind="Search" @bind:event="oninput" data-i18n-ph="search-placeholder" placeholder="Search by reference, customer, amount..." />
            </div>
            @foreach (var filter in Filters)
            {
                <button class="@FilterClass(filter.Value)" @onclick="() => SetFilter(filter.Value)" data-i18n="@filter.Key">@filter.Label</button>
            }
            <button class="filter-btn" @onclick="() => ActiveSheetId = FilterSheetId">@UiIcons.Filter <span data-i18n="btn-more-filters">More Filters</span></button>
        </div>

        <div class="inv-table">
            <div class="inv-thead">
                <div class="th sorted" data-i18n="th-ref">Reference <span class="sort">↓</span></div>
                <div class="th" data-i18n="th-customer">Customer</div>
                <div class="th" data-i18n="th-date">Date</div>
                <div class="th" data-i18n="th-type">Type</div>
                <div class="th" data-i18n="th-total">Total</div>
                <div class="th" data-i18n="th-paid">Paid</div>
                <div class="th" data-i18n="th-balance">Balance</div>
                <div class="th" data-i18n="th-status">Status</div>
                <div class="th"></div>
            </div>
            @foreach (var invoice in FilteredInvoices)
            {
                <div class="inv-row" @onclick="() => OpenInvoice(invoice)">
                    <InvoiceRow Item="invoice" OnView="OpenInvoice" />
                </div>
            }
            <div class="pagination">
                <span>Showing 1-@FilteredInvoices.Count of @Data.Summary.TotalCount</span>
                <div class="pag-btns">
                    <button class="pag-btn">‹</button>
                    <button class="pag-btn active">1</button>
                    <button class="pag-btn">2</button>
                    <button class="pag-btn">3</button>
                    <span style="padding:0 4px;color:var(--text-dim)">...</span>
                    <button class="pag-btn">25</button>
                    <button class="pag-btn">›</button>
                </div>
            </div>
        </div>
    </main>
</div>

<div class="mobile-wrap">
    <div class="mobile-frame">
        <div class="m-topbar">
            <button style="appearance:none;border:0;background:transparent;color:var(--text-muted);cursor:pointer;padding:4px">@UiIcons.Menu</button>
            <div style="text-align:center"><div class="m-eyebrow" data-i18n="nav-invoices">Invoices</div><h1 data-i18n="page-title">Sale Invoices</h1></div>
            <a href="/create-sale-invoice" style="appearance:none;border:0;background:var(--primary);color:#fff;width:32px;height:32px;border-radius:9px;display:grid;place-items:center;cursor:pointer;text-decoration:none">@UiIcons.Add</a>
        </div>
        <div class="m-body">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
                <div style="background:var(--success-soft);border:1px solid color-mix(in oklab,var(--success) 25%,var(--border));border-radius:12px;padding:12px">
                    <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--success-ink);font-weight:600;opacity:.8;margin-bottom:4px" data-i18n="stat-revenue">Revenue</div>
                    <div style="font-size:20px;font-weight:700;color:var(--success-ink);font-variant-numeric:tabular-nums">@Data.Summary.Revenue</div>
                </div>
                <div style="background:var(--danger-soft);border:1px solid color-mix(in oklab,var(--danger) 25%,var(--border));border-radius:12px;padding:12px">
                    <div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--danger-ink);font-weight:600;opacity:.8;margin-bottom:4px" data-i18n="stat-overdue">Overdue</div>
                    <div style="font-size:20px;font-weight:700;color:var(--danger-ink);font-variant-numeric:tabular-nums">@Data.Summary.Overdue</div>
                </div>
            </div>
            <div class="m-search">@UiIcons.Search <input @bind="Search" @bind:event="oninput" data-i18n-ph="search-mobile" placeholder="Search invoices..." /></div>
            <div class="m-chips">
                @foreach (var filter in Filters.Take(5))
                {
                    <button class="@FilterClass(filter.Value)" @onclick="() => SetFilter(filter.Value)" data-i18n="@filter.Key">@filter.Label</button>
                }
            </div>
            @foreach (var invoice in FilteredInvoices)
            {
                <div class="m-inv-card" @onclick="() => OpenInvoice(invoice)">
                    <InvoiceRow Item="invoice" Variant="InvoiceRowVariant.Mobile" />
                </div>
            }
        </div>
    </div>
</div>

<BottomSheets @bind-ActiveSheetId="ActiveSheetId">
    <BottomSheet Id="@FilterSheetId" Title="Filter Invoices" TitleI18nKey="sheet-filter-title">
        <ChildContent>
            <div class="f-group">
                <div class="f-label" data-i18n="filter-date-range">Date Range</div>
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><input class="input" type="date" value="2023-10-01" /><input class="input" type="date" value="2026-04-30" /></div>
            </div>
            <div class="f-group"><div class="f-label" data-i18n="filter-store">Store</div><select class="select"><option data-i18n="opt-all-stores">All Stores</option><option>Main Flagship Store</option><option>Main Downtown Hub</option><option>Airport Kiosk</option></select></div>
            <div class="f-group"><div class="f-label" data-i18n="filter-sale-type">Sale Type</div><select class="select" @bind="CurrentFilter"><option value="all">All Types</option><option value="cash">Cash</option><option value="installment">Installment</option><option value="credit">Credit</option><option value="advance">Advance</option></select></div>
            <div class="f-group"><div class="f-label" data-i18n="filter-amount">Amount Range</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><input class="input" placeholder="Min $" /><input class="input" placeholder="Max $" /></div></div>
        </ChildContent>
        <FooterContent>
            <button class="btn" @onclick="ResetFilters" data-i18n="btn-reset">Reset</button>
            <button class="btn primary" style="justify-content:center" @onclick="() => ActiveSheetId = null" data-i18n="btn-apply-filters">Apply Filters</button>
        </FooterContent>
    </BottomSheet>
</BottomSheets>

@code {
    private const string FilterSheetId = "sheet-filter";
    private InvoiceListData Data = default!;
    private string Search { get; set; } = string.Empty;
    private string CurrentFilter { get; set; } = "all";
    private string? ActiveSheetId { get; set; }

    private static readonly IReadOnlyList<BreadcrumbItem> Crumbs = [new("Invoices", I18nKey: "nav-invoices")];

    private static readonly IReadOnlyList<(string Label, string Value, string Key)> Filters =
    [
        ("All", "all", "chip-all"),
        ("Paid", "paid", "chip-paid"),
        ("Partial", "partial", "chip-partial"),
        ("Overdue", "overdue", "chip-overdue"),
        ("Draft", "draft", "chip-draft"),
        ("Voided", "voided", "chip-voided")
    ];

    protected override void OnInitialized()
    {
        Data = Demo.GetInvoiceList();
    }

    private IReadOnlyList<StatItem> Stats =>
    [
        new(Data.Summary.MonthlyTotal.ToString(), Label: "Invoices", LabelKey: "stat-invoices", Sub: "This period", SubKey: "stat-this-period"),
        new(Data.Summary.Revenue, "success", "Revenue", "stat-revenue", "Posted sales", "stat-posted-sales"),
        new(Data.Summary.Outstanding, "primary", "Outstanding", "stat-outstanding", $"{Data.Summary.OutstandingCount} open", "stat-open"),
        new(Data.Summary.Overdue, "danger", "Overdue", "stat-overdue", $"{Data.Summary.OverdueCount} invoices", "stat-overdue-count")
    ];

    private IReadOnlyList<InvoiceRowItem> FilteredInvoices
    {
        get
        {
            var query = Data.Invoices.AsEnumerable();

            if (CurrentFilter != "all")
            {
                query = CurrentFilter is "cash" or "installment" or "credit" or "advance"
                    ? query.Where(item => item.Type == CurrentFilter)
                    : query.Where(item => item.Status == CurrentFilter);
            }

            if (!string.IsNullOrWhiteSpace(Search))
            {
                query = query.Where(item =>
                    item.Reference.Contains(Search, StringComparison.OrdinalIgnoreCase)
                    || item.CustomerName.Contains(Search, StringComparison.OrdinalIgnoreCase)
                    || item.Total.ToString("0.00").Contains(Search, StringComparison.OrdinalIgnoreCase));
            }

            return query.ToArray();
        }
    }

    private string FilterClass(string value)
    {
        var active = CurrentFilter == value ? " active" : string.Empty;
        return $"filter-chip {value}{active}";
    }

    private void SetFilter(string value)
    {
        CurrentFilter = value;
    }

    private void ResetFilters()
    {
        Search = string.Empty;
        CurrentFilter = "all";
        ActiveSheetId = null;
    }

    private void OpenInvoice(InvoiceRowItem invoice)
    {
        Navigation.NavigateTo(invoice.Type == "cash" ? "/sale-invoice-details-cash" : "/sale-invoice-details");
    }
}
