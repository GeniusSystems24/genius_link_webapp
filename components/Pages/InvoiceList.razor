@page "/invoice-list"

<PageTitle>Invoice List</PageTitle>
<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/app.css" />
    <link rel="stylesheet" href="assets/css/invoice-list.css" />
</HeadContent>

<!-- Topbar -->
<div data-component="topbar"
     data-brand-href="/create-sale-invoice"
     data-crumbs='[{"label":"Invoices","key":"nav-invoices"}]'></div>

<!-- =================== DESKTOP =================== -->
<div class="desktop-wrap">
<main class="page">
  <div class="page-head">
    <div>
      <h1 data-i18n="page-title">Sale Invoices</h1>
      <div class="sub" data-i18n="page-sub">All transactions across stores and sale types.</div>
    </div>
    <div style="display:flex;gap:8px">
      <button class="btn" onclick="openSheet('sheet-filter')"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg><span data-i18n="btn-filter">Filters</span></button>
      <a href="/create-sale-invoice" class="btn primary"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg><span data-i18n="btn-new-invoice">New Invoice</span></a>
    </div>
  </div>

  <!-- Stats strip -->
  <div id="invoice-stats"></div>

  <!-- Filters -->
  <div class="filters">
    <div class="search-wrap">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <input id="search-input" oninput="filterRows()" data-i18n-ph="search-placeholder" placeholder="Search by reference, customer, amount…"/>
    </div>
    <button class="filter-chip all"     onclick="setFilter('all')"     id="chip-all"     data-i18n="chip-all">All</button>
    <button class="filter-chip paid"    onclick="setFilter('paid')"    id="chip-paid"    data-i18n="chip-paid">Paid</button>
    <button class="filter-chip partial" onclick="setFilter('partial')" id="chip-partial" data-i18n="chip-partial">Partial</button>
    <button class="filter-chip overdue" onclick="setFilter('overdue')" id="chip-overdue" data-i18n="chip-overdue">Overdue</button>
    <button class="filter-chip draft"   onclick="setFilter('draft')"   id="chip-draft"   data-i18n="chip-draft">Draft</button>
    <button class="filter-chip voided"  onclick="setFilter('voided')"  id="chip-voided"  data-i18n="chip-voided">Voided</button>
    <button class="filter-btn" onclick="openSheet('sheet-filter')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg><span data-i18n="btn-more-filters">More Filters</span></button>
  </div>

  <!-- Table -->
  <div class="inv-table">
    <div class="inv-thead">
      <div class="th sorted" data-i18n="th-ref">Reference <span class="sort">↓</span></div>
      <div class="th" data-i18n="th-customer">Customer</div>
      <div class="th" data-i18n="th-date">Date</div>
      <div class="th" data-i18n="th-type">Type</div>
      <div class="th" data-i18n="th-total">Total</div>
      <div class="th" data-i18n="th-paid">Paid</div>
      <div class="th" data-i18n="th-balance">Balance</div>
      <div class="th" data-i18n="th-status">Status</div>
      <div class="th"></div>
    </div>
    <div id="invoice-rows"></div>
    <div class="pagination">
      <span id="pag-info">Showing 1–10 of 248</span>
      <div class="pag-btns">
        <button class="pag-btn">‹</button>
        <button class="pag-btn active">1</button>
        <button class="pag-btn">2</button>
        <button class="pag-btn">3</button>
        <span style="padding:0 4px;color:var(--text-dim)">…</span>
        <button class="pag-btn">25</button>
        <button class="pag-btn">›</button>
      </div>
    </div>
  </div>
</main>
</div>

<!-- =================== MOBILE =================== -->
<div class="mobile-wrap">
  <div class="mobile-frame">
    <div class="m-topbar">
      <button style="appearance:none;border:0;background:transparent;color:var(--text-muted);cursor:pointer;padding:4px"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg></button>
      <div style="text-align:center"><div class="m-eyebrow" data-i18n="nav-invoices">Invoices</div><h1 data-i18n="page-title">Sale Invoices</h1></div>
      <a href="/create-sale-invoice" style="appearance:none;border:0;background:var(--primary);color:#fff;width:32px;height:32px;border-radius:9px;display:grid;place-items:center;cursor:pointer;text-decoration:none"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M12 5v14M5 12h14"/></svg></a>
    </div>
    <div class="m-body">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px">
        <div style="background:var(--success-soft);border:1px solid color-mix(in oklab,var(--success) 25%,var(--border));border-radius:12px;padding:12px"><div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--success-ink);font-weight:600;opacity:.8;margin-bottom:4px" data-i18n="stat-revenue">Revenue</div><div style="font-size:20px;font-weight:700;color:var(--success-ink);font-variant-numeric:tabular-nums">$84,320</div></div>
        <div style="background:var(--danger-soft);border:1px solid color-mix(in oklab,var(--danger) 25%,var(--border));border-radius:12px;padding:12px"><div style="font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--danger-ink);font-weight:600;opacity:.8;margin-bottom:4px" data-i18n="stat-overdue">Overdue</div><div style="font-size:20px;font-weight:700;color:var(--danger-ink);font-variant-numeric:tabular-nums">$3,180</div></div>
      </div>
      <div class="m-search"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg><input data-i18n-ph="search-mobile" placeholder="Search invoices…"/></div>
      <div class="m-chips">
        <button class="filter-chip all"     data-i18n="chip-all">All</button>
        <button class="filter-chip paid"    data-i18n="chip-paid">Paid</button>
        <button class="filter-chip partial" data-i18n="chip-partial">Partial</button>
        <button class="filter-chip overdue" data-i18n="chip-overdue">Overdue</button>
        <button class="filter-chip draft"   data-i18n="chip-draft">Draft</button>
      </div>
      <div id="m-invoice-cards"></div>
    </div>
  </div>
</div>

<!-- Filter Sheet -->
<div class="sheet-scrim" id="scrim" onclick="closeSheets()"></div>
<div class="sheet" id="sheet-filter">
  <div class="sheet-handle"></div>
  <div class="sheet-head"><h3 data-i18n="sheet-filter-title">Filter Invoices</h3><button style="appearance:none;border:0;background:transparent;color:var(--text-dim);cursor:pointer;position:absolute;right:16px;top:18px" onclick="closeSheets()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 6l12 12M6 18L18 6"/></svg></button></div>
  <div class="sheet-body">
    <div class="f-group"><div class="f-label" data-i18n="filter-date-range">Date Range</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><input class="input" type="date" value="2023-10-01"/><input class="input" type="date" value="2023-12-31"/></div>
    </div>
    <div class="f-group"><div class="f-label" data-i18n="filter-store">Store</div><select class="select"><option data-i18n="opt-all-stores">All Stores</option><option>Main Flagship Store</option><option>Main Downtown Hub</option><option>Airport Kiosk</option></select></div>
    <div class="f-group"><div class="f-label" data-i18n="filter-sale-type">Sale Type</div><select class="select"><option data-i18n="opt-all-types">All Types</option><option data-i18n="type-cash">Cash</option><option data-i18n="type-installment">Installment</option><option data-i18n="type-credit">Credit</option></select></div>
    <div class="f-group"><div class="f-label" data-i18n="filter-amount">Amount Range</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><input class="input" placeholder="Min $"/><input class="input" placeholder="Max $"/></div>
    </div>
    <div class="f-group"><div class="f-label" data-i18n="filter-sort">Sort By</div><select class="select"><option data-i18n="sort-date-desc">Date (Newest first)</option><option data-i18n="sort-date-asc">Date (Oldest first)</option><option data-i18n="sort-amount-desc">Amount (High to Low)</option><option data-i18n="sort-balance-desc">Balance (High to Low)</option></select></div>
  </div>
  <div class="sheet-footer"><button class="btn" onclick="closeSheets()" data-i18n="btn-reset">Reset</button><button class="btn primary" style="justify-content:center" onclick="closeSheets()" data-i18n="btn-apply-filters">Apply Filters</button></div>
</div>

<script src="assets/js/theme.js"></script>
<script src="assets/js/view.js"></script>
<script src="assets/js/i18n.js"></script>
<script src="assets/js/format.js"></script>
<script src="assets/js/data-loader.js"></script>
<script src="assets/js/app-bootstrap.js"></script>
<script src="assets/js/components.js"></script>
<script src="assets/js/invoice-list.js"></script>
<script src="arabic-page-helper.js"></script>
