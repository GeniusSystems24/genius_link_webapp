@page "/record-payment"
@inject DemoDataService Demo
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>Record Payment</PageTitle>
<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="assets/css/app.css" />
    <link rel="stylesheet" href="assets/css/record-payment.css" />
</HeadContent>

<Topbar BrandHref="/invoice-list" Crumbs="Crumbs" />

<div class="desktop-wrap">
    <main class="page">
        <Stepper Steps="Steps" @bind-CurrentStep="CurrentStep" />

        <div class="@PanelClass(1)">
            <div class="card">
                <div class="card-head"><div><div class="card-title">Select Invoice to Pay</div><div class="card-sub">Choose one or more outstanding invoices for this customer.</div></div></div>
                <div class="card-body">
                    <div class="field"><label>Customer</label><div style="position:relative">@UiIcons.Search <input class="input" style="padding-left:36px" value="@SelectedInvoice.Customer" /></div></div>
                    <div class="field">
                        <label>Outstanding Invoices</label>
                        @foreach (var invoice in PaymentData.OutstandingInvoices)
                        {
                            <div class="@InvoiceOptionClass(invoice)" @onclick="() => SelectInvoice(invoice)">
                                <div class="check">@if (SelectedInvoice.Reference == invoice.Reference) { @UiIcons.Check }</div>
                                <div class="info"><div class="ref">@invoice.Reference</div><div class="cust">@invoice.Customer</div><div class="sub">@invoice.Sub</div><div class="sub">@invoice.Note</div></div>
                                <span class="badge">@invoice.Status</span>
                                <div class="balance">@UiFormat.Money(invoice.Balance)</div>
                            </div>
                        }
                    </div>
                    <div class="step-nav">
                        <a href="/sale-invoice-details" class="btn ghost">Cancel</a>
                        <button class="btn primary" @onclick="Next">Next @UiIcons.View</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="@PanelClass(2)">
            <div class="card">
                <div class="card-head"><div><div class="card-title">Payment Details</div><div class="card-sub">Enter the amount, method, and account for this payment.</div></div></div>
                <div class="card-body">
                    <div class="field">
                        <label>Amount</label>
                        <div class="big-amt-wrap"><span class="cur">$</span><input class="input big-amt" @bind="PaymentAmount" /></div>
                        <div style="display:flex;gap:8px;margin-top:8px">@if (PaymentData.Allocations.Count > 0) { <button class="btn" style="font-size:12px;padding:6px 12px" @onclick="() => PaymentAmount = PaymentData.Allocations[0].Amount">@PaymentData.Allocations[0].Label</button> }<button class="btn" style="font-size:12px;padding:6px 12px" @onclick="() => PaymentAmount = SelectedInvoice.Balance">Pay All (@UiFormat.Money(SelectedInvoice.Balance))</button></div>
                    </div>
                    <div class="field"><label>Payment Method</label><div class="seg cols3">@foreach (var method in Methods) { <button class="@(PaymentMethod == method ? "active" : null)" @onclick="() => PaymentMethod = method">@method</button> }</div></div>
                    <div class="grid2"><div class="field"><label>Account</label><select class="select" @bind="Account"><option>Main Bank Account (1002-01)</option><option>Petty Cash (1001-01)</option></select></div><div class="field"><label>Payment Date</label><input class="input" @bind="PaymentDate" /></div></div>
                    <div class="field">
                        <label>Allocate to Installments</label>
                        @foreach (var allocation in PaymentData.Allocations)
                        {
                            <label class="@AllocationClass(allocation)">
                                <input type="checkbox" checked="@SelectedAllocations.Contains(allocation.Label)" @onchange="eventArgs => ToggleAllocation(allocation.Label, eventArgs)" />
                                <div class="al"><div class="t">@allocation.Label</div><div class="s">@allocation.Sub</div></div>
                                <div class="amt">@UiFormat.Money(allocation.Amount)</div>
                            </label>
                        }
                    </div>
                    <div class="field"><label>Reference / Receipt #</label><input class="input" @bind="Reference" placeholder="e.g. BANK-TXN-20240101" /></div>
                    <div class="field"><label>Notes</label><input class="input" @bind="Notes" placeholder="Optional..." /></div>
                    <div class="step-nav"><button class="btn ghost" @onclick="Back">@UiIcons.View Back</button><button class="btn primary" @onclick="Next">Review @UiIcons.View</button></div>
                </div>
            </div>
        </div>

        <div class="@PanelClass(3)">
            <div class="card">
                <div class="card-head"><div><div class="card-title">Review Payment</div><div class="card-sub">Confirm all details before posting the journal entry.</div></div></div>
                <div class="card-body">
                    <div class="grid2" style="margin-bottom:16px">
                        <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:12px;padding:16px"><div style="font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-dim);font-weight:600;margin-bottom:8px">Invoice</div><div class="mono" style="font-weight:600;color:var(--primary)">@SelectedInvoice.Reference</div><div style="font-weight:600;margin-top:4px">@SelectedInvoice.Customer</div><div style="font-size:12px;color:var(--text-muted);margin-top:2px">@SelectedAllocationsText</div></div>
                        <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:12px;padding:16px"><div style="font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--text-dim);font-weight:600;margin-bottom:8px">Payment</div><div style="font-size:22px;font-weight:700;color:var(--success);font-variant-numeric:tabular-nums">@UiFormat.Money(PaymentAmount)</div><div style="font-size:12.5px;color:var(--text-muted);margin-top:4px">@PaymentMethod - @Account</div><div style="font-size:12px;color:var(--text-dim);margin-top:2px">@PaymentDate</div></div>
                    </div>
                    <div class="summary-box">
                        <div class="s-row"><span class="k">Invoice Balance</span><span class="v">@UiFormat.Money(SelectedInvoice.Balance)</span></div>
                        <div class="s-row"><span class="k">This Payment</span><span class="v success">@UiFormat.Money(PaymentAmount)</span></div>
                        <div class="s-row"><span class="k">Balance After</span><span class="v danger">@UiFormat.Money(BalanceAfter)</span></div>
                    </div>
                    <div style="background:var(--amber-soft);border:1px solid var(--amber);border-radius:10px;padding:12px 14px;margin-top:14px;font-size:13px;color:var(--amber-ink)">Once confirmed, this payment will post a journal entry immediately.</div>
                    <div class="step-nav"><button class="btn ghost" @onclick="Back">@UiIcons.View Back</button><button class="btn primary" @onclick="Next">@UiIcons.Check Confirm & Post</button></div>
                </div>
            </div>
        </div>

        <div class="@PanelClass(4)">
            <div class="success-anim">
                <div class="receipt">
                    <div class="r-badge">@UiIcons.Check <span>Payment Posted</span></div>
                    <div class="r-amount">@UiFormat.Money(PaymentAmount)</div>
                    <div class="r-sub">Successfully recorded and posted to ledger</div>
                    <div class="r-grid"><div class="r-cell"><div class="rl">Invoice</div><div class="rv mono">@SelectedInvoice.Reference</div></div><div class="r-cell"><div class="rl">Date</div><div class="rv">@PaymentDate</div></div><div class="r-cell"><div class="rl">Method</div><div class="rv">@PaymentMethod</div></div><div class="r-cell"><div class="rl">Remaining</div><div class="rv">@UiFormat.Money(BalanceAfter)</div></div></div>
                </div>
                <div class="card"><div class="card-body"><div style="text-align:center;padding:8px 0 16px"><div class="check-circle success-anim">@UiIcons.Check</div><div style="font-size:18px;font-weight:700;margin-bottom:6px">Payment Recorded Successfully</div><div style="color:var(--text-muted);font-size:13px">Journal entries have been posted automatically.</div></div><div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px"><button class="btn" @onclick="Print">@UiIcons.Print <span>Print</span></button><a href="/sale-invoice-details" class="btn">@UiIcons.View <span>View Invoice</span></a><a href="/record-payment" class="btn primary">@UiIcons.Add <span>New Payment</span></a></div></div></div>
            </div>
        </div>
    </main>
</div>

<div class="mobile-wrap">
    <div class="mobile-frame">
        <div class="m-topbar"><button class="icon-btn" @onclick="Back">@UiIcons.View</button><div style="text-align:center"><div class="m-eyebrow">Record Payment</div><h1>@Steps[CurrentStep - 1].Label</h1></div><button class="icon-btn">@UiIcons.More</button></div>
        <div class="m-body">
            <Stepper Steps="Steps" @bind-CurrentStep="CurrentStep" Mobile="true" />
            @if (CurrentStep == 1)
            {
                <div style="margin-bottom:12px;font-size:13px;color:var(--text-muted)">Choose outstanding invoices to pay.</div>
                @foreach (var invoice in PaymentData.OutstandingInvoices)
                {
                    <div class="@InvoiceOptionClass(invoice)" @onclick="() => SelectInvoice(invoice)"><div class="check">@if (SelectedInvoice.Reference == invoice.Reference) { @UiIcons.Check }</div><div class="info"><div class="ref">@invoice.Reference</div><div class="cust">@invoice.Customer</div><div class="sub">@invoice.Sub</div></div><div class="balance">@UiFormat.Money(invoice.Balance)</div></div>
                }
            }
            else if (CurrentStep == 2)
            {
                <div class="field"><label>Amount</label><div class="big-amt-wrap"><span class="cur">$</span><input class="input big-amt" @bind="PaymentAmount" /></div></div>
                <div class="field"><label>Payment Method</label><div class="seg cols3">@foreach (var method in Methods) { <button class="@(PaymentMethod == method ? "active" : null)" @onclick="() => PaymentMethod = method">@method</button> }</div></div>
                <div class="field"><label>Account</label><select class="select" @bind="Account"><option>Main Bank Account (1002-01)</option><option>Petty Cash (1001-01)</option></select></div>
                @foreach (var allocation in PaymentData.Allocations)
                {
                    <label class="@AllocationClass(allocation)"><input type="checkbox" checked="@SelectedAllocations.Contains(allocation.Label)" @onchange="eventArgs => ToggleAllocation(allocation.Label, eventArgs)" /><div class="al"><div class="t">@allocation.Label</div><div class="s">@allocation.Sub</div></div><div class="amt">@UiFormat.Money(allocation.Amount)</div></label>
                }
            }
            else if (CurrentStep == 3)
            {
                <div style="background:var(--primary-soft);border:1px solid color-mix(in oklab,var(--primary) 25%,var(--border));border-radius:14px;padding:16px;margin-bottom:14px"><div style="font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--primary-ink);font-weight:600;margin-bottom:8px">Payment</div><div style="font-size:28px;font-weight:700;color:var(--primary-ink);font-variant-numeric:tabular-nums">@UiFormat.Money(PaymentAmount)</div><div style="font-size:12.5px;color:var(--primary-ink);opacity:.75;margin-top:4px">@PaymentMethod - @Account</div></div>
                <div class="summary-box"><div class="s-row"><span class="k">Invoice Balance</span><span class="v">@UiFormat.Money(SelectedInvoice.Balance)</span></div><div class="s-row"><span class="k">This Payment</span><span class="v success">@UiFormat.Money(PaymentAmount)</span></div><div class="s-row"><span class="k">Balance After</span><span class="v danger">@UiFormat.Money(BalanceAfter)</span></div></div>
            }
            else
            {
                <div style="text-align:center;padding:16px 0 24px"><div class="check-circle success-anim">@UiIcons.Check</div><div style="font-size:20px;font-weight:700;margin-bottom:6px">Payment Recorded!</div><div style="color:var(--text-muted);font-size:13px">Journal entries posted automatically.</div></div>
                <div class="receipt"><div class="r-badge">Posted</div><div class="r-amount">@UiFormat.Money(PaymentAmount)</div><div class="r-sub">@SelectedInvoice.Reference - @PaymentDate</div></div>
            }
        </div>
        <div class="mobile-footer"><button class="btn" @onclick="Back">Back</button><button class="btn primary" @onclick="Next" style="justify-content:center">@(CurrentStep == 4 ? "Done" : "Next")</button></div>
    </div>
</div>

@code {
    private PaymentOptionsData PaymentData = default!;
    private PaymentInvoiceOption SelectedInvoice = default!;
    private readonly HashSet<string> SelectedAllocations = [];
    private int CurrentStep { get; set; } = 1;
    private decimal PaymentAmount { get; set; }
    private string PaymentMethod { get; set; } = "Bank Transfer";
    private string Account { get; set; } = "Main Bank Account (1002-01)";
    private string PaymentDate { get; set; } = "2024-01-01";
    private string Reference { get; set; } = "BANK-TXN-20240101";
    private string Notes { get; set; } = string.Empty;

    private static readonly IReadOnlyList<BreadcrumbItem> Crumbs = [new("Invoices", "/invoice-list", "nav-invoices"), new("INV-2023-007", "/sale-invoice-details"), new("Record Payment")];
    private static readonly IReadOnlyList<StepperStep> Steps = [new(1, "step-1", "Select Invoice"), new(2, "step-2", "Payment Details"), new(3, "step-3", "Review"), new(4, "step-4", "Receipt")];
    private static readonly IReadOnlyList<string> Methods = ["Bank Transfer", "Cash", "Card"];

    protected override void OnInitialized()
    {
        PaymentData = Demo.GetPaymentOptions();
        SelectedInvoice = PaymentData.OutstandingInvoices[0];
        foreach (var allocation in PaymentData.Allocations.Where(item => item.Checked))
        {
            SelectedAllocations.Add(allocation.Label);
        }
        var firstChecked = PaymentData.Allocations.FirstOrDefault(a => a.Checked);
        PaymentAmount = firstChecked?.Amount ?? SelectedInvoice.Balance;
    }

    private decimal BalanceAfter => Math.Max(0, SelectedInvoice.Balance - PaymentAmount);
    private string SelectedAllocationsText => SelectedAllocations.Count == 0 ? "No installment selected" : string.Join(", ", SelectedAllocations);
    private string PanelClass(int step)
    {
        return CurrentStep == step ? "step-panel active" : "step-panel";
    }

    private string InvoiceOptionClass(PaymentInvoiceOption invoice)
    {
        return SelectedInvoice.Reference == invoice.Reference ? "inv-option selected" : "inv-option";
    }

    private string AllocationClass(PaymentAllocationOption allocation)
    {
        var selected = SelectedAllocations.Contains(allocation.Label) ? " selected" : string.Empty;
        var overdue = allocation.Overdue ? " overdue" : string.Empty;
        return $"alloc-item{selected}{overdue}";
    }

    private void SelectInvoice(PaymentInvoiceOption invoice)
    {
        SelectedInvoice = invoice;
        PaymentAmount = Math.Min(PaymentAmount, invoice.Balance);
    }

    private void ToggleAllocation(string label, ChangeEventArgs eventArgs)
    {
        if (eventArgs.Value is true || string.Equals(eventArgs.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase))
        {
            SelectedAllocations.Add(label);
        }
        else
        {
            SelectedAllocations.Remove(label);
        }
    }

    private void Next()
    {
        CurrentStep = Math.Min(4, CurrentStep + 1);
    }

    private void Back()
    {
        CurrentStep = Math.Max(1, CurrentStep - 1);
    }

    private async Task Print()
    {
        await JS.InvokeVoidAsync("GeniusApp.print");
    }
}
