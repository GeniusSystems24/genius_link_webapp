        <option data-i18n="void-reason-pricing">Pricing error</option>
        <option data-i18n="void-reason-other">Other</option>
      </select>
    </div>
    <div class="field">
      <label data-i18n="lbl-notes">Notes</label>
      <input class="input" data-i18n-ph="ph-void-notes" placeholder="Optional details…"/>
    </div>
  </div>
  <div class="sheet-footer">
    <button class="btn" onclick="closeSheets()" data-i18n="btn-keep-invoice">Keep Invoice</button>
    <button class="btn danger" style="justify-content:center" onclick="closeSheets()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M6 6l12 12"/></svg>
      <span data-i18n="sheet-void-title">Void Invoice</span>
    </button>
  </div>
</div>

